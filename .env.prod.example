# Database
DATABASE_URL=sqlite:./data/knowledge.db

# Security — generate with: openssl rand -hex 32
JWT_SECRET=
ENCRYPTION_KEY=

# AI
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# App
PORT=8080
FRONTEND_URL=http://YOUR_SERVER_IP
RUST_LOG=knowledge_api=info,tower_http=info

# Build arg for the web container (not read at runtime by the API).
# Set this before running: docker compose -f docker-compose.prod.yml build
VITE_API_URL=http://YOUR_SERVER_IP:8181
