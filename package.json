{
  "name": "knowledge-assistant",
  "version": "0.1.0",
  "author": "VS-Dev",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter web dev & cargo watch -x run --manifest-path apps/api/Cargo.toml",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm --filter web test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
     "apps/web/src/**/*.{ts,tsx}": ["biome check --apply"],
     "apps/api/src/**/*.rs": ["cargo fmt --"]
   },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
